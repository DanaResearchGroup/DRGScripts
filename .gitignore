################################################################################
#
#   Files for git to ignore
#
################################################################################

# MacOS files
.DS_Store

# Compiled Python modules
*.pyc
*.so
*.pyd

# PyCharm project files
.idea/*
venv/

# VS Code Local History files
.history/*

# Projects
Projects/

# Examples
examples/

# Unit test files
.coverage
testing/*
htmlcov/*
arc/testing/gcn_tst/

# Scratch
scratch/

# csv database
*.csv
# but keep example inputs for the kinetics-extraction scripts
!Kinetics_lib/files/*.csv
!Pdep/files/*.csv

# iPython files
*.ipynb_*
*/.ipynb_*

# Compiled documentation
docs/build/*

# deleted files
**/.fuse_hidden*

# timer.dat
timer.dat

# .vscode
.vscode

# Superpowers working files (brainstorming specs, plans) — local-only, never tracked
docs/superpowers/
